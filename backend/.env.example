# ── MySQL ──────────────────────────────────────────────────────────────────────
# Connection details for the MySQL database.
# All fields can be overridden by setting DATABASE_URL directly.
MYSQL_USER=portfolio
MYSQL_PASSWORD=portfolio
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=portfolio

# Alternatively, set the full SQLAlchemy URL (takes precedence over the above):
# DATABASE_URL=mysql+pymysql://portfolio:portfolio@localhost:3306/portfolio

# Connection pool recycle time in seconds (default: 1800 = 30 minutes).
# Tune this based on your MySQL server's wait_timeout setting.
DB_POOL_RECYCLE=1800

# ── Redis ──────────────────────────────────────────────────────────────────────
# Full Redis URL used for API response caching.
REDIS_URL=redis://localhost:6379/0

# Cache TTL in seconds (default: 300 = 5 minutes).
CACHE_TTL=300
